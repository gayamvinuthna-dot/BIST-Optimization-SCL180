module misr (
    input clk,
    input rst,
    input data_in,
    output reg [7:0] signature
);

wire feedback;

assign feedback = signature[7] ^ data_in;

always @(posedge clk or posedge rst)
begin
    if(rst)
        signature <= 8'b0;
    else
        signature <= {signature[6:0], feedback};
end

endmodule
