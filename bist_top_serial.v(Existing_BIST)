module bist_top_serial (
    input clk,
    input rst,
    output [7:0] test_pattern,
    output xor_result,
    output [7:0] signature
);

wire [7:0] lfsr_pattern;

lfsr U1 (
    .clk(clk),
    .rst(rst),
    .lfsr_out(lfsr_pattern)
);

sdm U2 (
    .clk(clk),
    .rst(rst),
    .serial_in(lfsr_pattern[0]),
    .data_out(test_pattern)
);

cxm_serial U3 (
    .data_in(test_pattern),
    .xor_out(xor_result)
);

misr U4 (
    .clk(clk),
    .rst(rst),
    .data_in(xor_result),
    .signature(signature)
);

endmodule
