# ============================================================
# OPTIMIZED DESIGN PD FLOW
# Technology : SCL180 / GPDK180
# ============================================================

# ------------------------------------------------------------
# 1. DESIGN INPUTS
# ------------------------------------------------------------

set init_verilog "netlists/bist_top_optimized_netlist.v"

set init_top_cell "bist_top_optimized"

# ------------------------------------------------------------
# 2. LEF FILES
# ------------------------------------------------------------

set init_lef_file {
\
/mnt/hgfs/scl_bridge/SCLPDK_V3.0_KIT/scl180/stdcell/fs120/6M1L/lef/scl18fs120_tech.lef
\
/mnt/hgfs/scl_bridge/SCLPDK_V3.0_KIT/scl180/stdcell/fs120/6M1L/lef/scl18fs120_std.lef
}

# ------------------------------------------------------------
# 3. MMMC FILE
# ------------------------------------------------------------

set init_mmmc_file "mmmc.tcl"

# ------------------------------------------------------------
# 4. INITIALIZE DESIGN
# ------------------------------------------------------------

init_design

# ------------------------------------------------------------
# 5. FLOORPLAN
# ------------------------------------------------------------

floorPlan -site CoreSite \
-r 1.0 0.7 20 20 20 20

# ------------------------------------------------------------
# 6. POWER RINGS
# ------------------------------------------------------------

addRing \
-nets {VDD VSS} \
-type core_rings \
-layer {top M5 bottom M5 left M4 right M4} \
-width 2 \
-spacing 1

# ------------------------------------------------------------
# 7. PLACEMENT
# ------------------------------------------------------------

placeDesign

# ------------------------------------------------------------
# 8. CLOCK TREE SYNTHESIS
# ------------------------------------------------------------

clockDesign

# ------------------------------------------------------------
# 9. ROUTING
# ------------------------------------------------------------

routeDesign

# ------------------------------------------------------------
# 10. SAVE DESIGN
# ------------------------------------------------------------

saveDesign final_pd_opt.enc

puts "=== OPTIMIZED PD DONE ==="
